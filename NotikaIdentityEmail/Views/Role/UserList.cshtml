@model List<AppUser>

@{
    Layout = "_Layout";
    int count = 0;
}

<div class="form-element-area">
    <div class="container">
        <div class="row">
            <div class="col-lg-12 col-md-12 col-sm-12 col-xs-12">
                <div class="form-element-list">
                    <div class="row">
                        <table class="table table-bordered">
                            <tr>
                                <th>#</th>
                                <th>Ad Soyad</th>
                                <th>Kullanıcı Adı</th>
                                <th>Email</th>
                                <th>Rol Atama</th>
                            </tr>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@(++count)</td>
                                    <td>@item.Name @item.Surname</td>
                                    <td>@item.UserName</td>
                                    <td>@item.Email</td>
                                    <td><a href="/Role/AssignRole/@item.Id" class="btn btn-warning">Rol Ata</a></td>
                                </tr>
                            }
                        </table>
                        <a href="/Role/CreateRole/" class="btn btn-primary">Yeni Rol Ekle</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>