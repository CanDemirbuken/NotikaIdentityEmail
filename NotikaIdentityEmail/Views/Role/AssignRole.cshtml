@model List<RoleAssignViewModel>

@{
    Layout = "_Layout";
    int count = 0;
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-12">

            <div class="card shadow-sm rounded-4 border-0">
                <div class="card-header bg-primary text-white rounded-top-4">
                    <h3 class="mb-0">👥 Kullanıcı - Rol Atama</h3>
                </div>
                <div class="card-body">

                    <form method="post">
                        <div class="list-group list-group-flush mb-4">
                            @for (int i = 0; i < Model.Count; i++)
                            {
                                <div class="form-check list-group-item">
                                    <input type="hidden" asp-for="@Model[i].Id" />
                                    <input type="hidden" asp-for="@Model[i].Role" />
                                    <input class="form-check-input" type="checkbox" asp-for="@Model[i].Exist" id="roleCheck_@i">
                                    <label class="form-check-label fw-semibold ms-2" for="roleCheck_@i">
                                        @Model[i].Role
                                    </label>
                                </div>
                            }
                        </div>

                        <div class="text-end">
                            <button type="submit" class="btn btn-success px-4">
                                💾 Değişiklikleri Kaydet
                            </button>
                        </div>
                    </form>

                </div>
            </div>

        </div>
    </div>
</div>
